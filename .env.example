# Salin file ini menjadi .env lalu sesuaikan nilainya.

# Koneksi PostgreSQL lokal
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hackathon_db?sslmode=disable

# Secret untuk menandatangani JWT — ganti dengan nilai acak yang panjang
JWT_SECRET=change-me-to-a-long-random-string

# Masa berlaku token (format Go duration: 24h, 30m, dst.)
JWT_EXPIRES_IN=24h

PORT=3000
